{
	"schemaVersion": 1,
	"id": "earlycompat",
	"version": "${version}",
	"name": "EarlyCompat",
	"description": "This mod adds local protocol compatibility and bug fixes for ported blocks.",
	"authors": [
		"chenjunfu2"
	],
	"contact": {
		"homepage": "NULL",
		"sources": "https://github.com/chenjunfu2/EarlyCompat"
	},
	"license": "CC0-1.0",
	"icon": "assets/earlycompat/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"chenjunfu2.earlycompat.EarlyCompat"
		],
		"client": [
			"chenjunfu2.earlycompat.client.EarlyCompatClient"
		]
	},
	"mixins": [
		"earlycompat.mixins.json",
		{
			"config": "earlycompat.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.16.0",
		"minecraft": "~1.20.1",
		"java": ">=17",
		"fabric-api": "*"
